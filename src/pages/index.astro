---
import AboutSection from '../components/about-section.astro';
import ClientPreferences from '../components/client-preferences.astro';
import ContentSection from '../components/content-section.astro';
import ExperienceSection from '../components/experience-section.astro';
import HeroSection from '../components/hero-section.astro';
import Layout from '../layouts/layout.astro';
import ProjectsSection from '../components/projects-section.astro';
import SiteHeader from '../components/site-header.astro';

import { sections } from '../lib/site';
---

<Layout>
	<SiteHeader />
	<main class="mx-auto w-[min(1120px,calc(100%_-_2rem))]">
		<HeroSection />
		<AboutSection />
		<ProjectsSection />
		<ExperienceSection />
		{sections.map(
			(section) =>
				<ContentSection
					id={section.id}
					sectionKey={section.key}
				/>
		)}
	</main>
	<ClientPreferences />
</Layout>
