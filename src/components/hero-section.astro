---
import { t } from '../lib/site';
---

<section class="hero-section" id="inicio" aria-labelledby="hero-title">
	<div class="hero-copy">
		<p class="eyebrow" data-i18n="hero.eyebrow">{t('hero.eyebrow')}</p>
		<h1 id="hero-title" data-i18n="hero.title">{t('hero.title')}</h1>
		<p class="hero-text" data-i18n="hero.text">{t('hero.text')}</p>
		<div class="hero-actions">
			<a class="primary-link" href="#projetos" data-i18n="hero.primary">{t('hero.primary')}</a>
			<a class="secondary-link" href="#contato" data-i18n="hero.secondary">{t('hero.secondary')}</a>
		</div>
	</div>

	<div class="profile-panel" aria-label="Resumo">
		<span class="panel-label" data-i18n="profile.label">{t('profile.label')}</span>
		<p data-i18n="profile.text">{t('profile.text')}</p>
	</div>
</section>
