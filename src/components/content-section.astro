---
import type { MessageKey } from '../lib/site';
import { t } from '../lib/site';

interface Props {
	id: string;
	sectionKey: string;
}

const { id, sectionKey } = Astro.props;
const eyebrowKey = `sections.${sectionKey}.eyebrow` as MessageKey;
const titleKey = `sections.${sectionKey}.title` as MessageKey;
const textKey = `sections.${sectionKey}.text` as MessageKey;
---

<section
	class="grid scroll-mt-20 grid-cols-[minmax(0,0.75fr)_minmax(0,1fr)] gap-[clamp(1.5rem,4vw,4rem)] border-t border-[var(--line)] py-[clamp(4rem,9vw,7rem)] max-[820px]:grid-cols-1"
	id={id}
>
	<div>
		<p class="mb-3.5 text-xs font-extrabold uppercase text-[var(--accent)]" data-i18n={eyebrowKey}>
			{t(eyebrowKey)}
		</p>
		<h2 class="text-[clamp(2rem,4vw,3.4rem)] leading-none" data-i18n={titleKey}>{t(titleKey)}</h2>
	</div>
	<p class="leading-7 text-[var(--muted)]" data-i18n={textKey}>{t(textKey)}</p>
</section>
