---
export interface Props {
  images: {
		src: string,
		alt: string,
		altKey?: string,
	}[];
	label?: string;
}

const { images, label = 'Galeria de imagens' } = Astro.props;
---

<div
  data-photo-carousel
  class="relative mx-auto h-[390px] w-full overflow-hidden max-[640px]:h-[310px]"
  aria-label={label}
>
  {
    images.map((image, index) => (
      <button
        type="button"
        data-carousel-item
        data-index={index}
        aria-label={image.alt}
        class="absolute left-1/2 top-1/2 aspect-[16/10] w-[min(90vw,560px)] cursor-pointer overflow-hidden rounded-lg border border-[var(--line)] bg-[#0f1f30] p-1 transition-all duration-500 ease-out hover:brightness-110 focus:outline-none focus:ring-4 focus:ring-[color-mix(in_srgb,var(--accent)_35%,transparent)] max-[640px]:w-[270px]"
      >
        <img
          src={image.src}
          alt={image.alt}
          class="h-full w-full rounded-md object-contain object-top"
          loading={index === 0 ? 'eager' : 'lazy'}
          decoding="async"
          data-i18n-attr={image.altKey ? `alt:${image.altKey}` : undefined}
        />
      </button>
    ))
  }
</div>

<script>
  const carousels = document.querySelectorAll("[data-photo-carousel]");

  carousels.forEach((carousel) => {
    const items = Array.from(
      carousel.querySelectorAll("[data-carousel-item]"),
    ) as HTMLButtonElement[];

    let activeIndex = Math.floor(items.length / 2);

    function getCircularDiff(
			index: number,
			activeIndex: number,
			total: number,
		) {
      let diff = index - activeIndex;

      if (diff > total / 2) {
        diff -= total;
      }

      if (diff < -total / 2) {
        diff += total;
      }

      return diff;
    }

    function getItemStyle(diff: number, total: number) {
      const direction = Math.sign(diff);
      const distance = Math.abs(diff);

      if (distance === 0) {
        return {
          x: -50,
          rotate: 0,
          scale: 1,
          opacity: 1,
          zIndex: total + 10,
          pointerEvents: "auto",
        };
      }

      const visibleDistance = Math.min(distance, 3);

      const x =
        direction < 0
          ? -50 - visibleDistance * 19
          : -50 + visibleDistance * 19;

      const rotate = direction * Math.min(visibleDistance * 5, 15);
      const scale = Math.max(1 - visibleDistance * 0.08, 0.72);
      const opacity = Math.max(1 - visibleDistance * 0.16, 0.25);
      const zIndex = total + 10 - visibleDistance;

      return {
        x,
        rotate,
        scale,
        opacity,
        zIndex,
        pointerEvents: distance <= 3 ? "auto" : "none",
      };
    }

    function updateCarousel() {
      const total = items.length;

      items.forEach((item, index) => {
        const diff = getCircularDiff(index, activeIndex, total);
        const style = getItemStyle(diff, total);

        item.style.transform = `
          translate(${style.x}%, -50%)
          rotate(${style.rotate}deg)
          scale(${style.scale})
        `;

        item.style.opacity = `${style.opacity}`;
        item.style.zIndex = `${style.zIndex}`;
        item.style.pointerEvents = style.pointerEvents;

        item.setAttribute("aria-current", diff === 0 ? "true" : "false");
        item.dataset.active = diff === 0 ? "true" : "false";
      });
    }

    items.forEach((item, index) => {
      item.addEventListener("click", () => {
        activeIndex = index;
        updateCarousel();
      });
    });

    updateCarousel();
  });
</script>
