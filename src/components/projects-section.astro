---
import { t } from '../lib/site';
---

<section
	class="scroll-mt-20 border-t border-[var(--line)] py-[clamp(4rem,9vw,7rem)]"
	id="projetos"
	aria-labelledby="projects-title"
>
	<div class="grid grid-cols-[minmax(0,0.75fr)_minmax(0,1fr)] gap-[clamp(1.5rem,4vw,4rem)] max-[820px]:grid-cols-1">
		<div>
			<p class="mb-3.5 text-xs font-extrabold uppercase text-[var(--accent)]" data-i18n="projects.eyebrow">
				{t('projects.eyebrow')}
			</p>
			<h2 class="text-[clamp(2rem,4vw,3.4rem)] leading-none" id="projects-title" data-i18n="projects.title">
				{t('projects.title')}
			</h2>
		</div>
	</div>

	<p class="mt-8 rounded-lg border border-[var(--line)] bg-[var(--surface)] p-5 text-[var(--muted)]" data-projects-status data-i18n="projects.loading">
		{t('projects.loading')}
	</p>

	<div class="mt-8 grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-3 max-[640px]:gap-2">
		<button
			class="grid size-11 place-items-center rounded-full border border-[var(--line)] bg-[var(--surface)] text-[var(--text)] transition hover:bg-[var(--surface-muted)]"
			type="button"
			data-projects-prev
			aria-label={t('projects.previous')}
			data-i18n-attr="aria-label:projects.previous"
		>
			<svg class="size-4 fill-none stroke-current stroke-2" viewBox="0 0 24 24" aria-hidden="true">
				<path d="m15 18-6-6 6-6"></path>
			</svg>
		</button>

		<div
			class="scrollbar-none hidden bg-transparent snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth"
			data-projects-track
			aria-label={t('projects.carousel')}
			data-i18n-attr="aria-label:projects.carousel"
		>
		</div>

		<button
			class="grid size-11 place-items-center rounded-full border border-[var(--line)] bg-[var(--surface)] text-[var(--text)] transition hover:bg-[var(--surface-muted)]"
			type="button"
			data-projects-next
			aria-label={t('projects.next')}
			data-i18n-attr="aria-label:projects.next"
		>
			<svg class="size-4 fill-none stroke-current stroke-2" viewBox="0 0 24 24" aria-hidden="true">
				<path d="m9 18 6-6-6-6"></path>
			</svg>
		</button>
	</div>
</section>
